generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("competitor_monitor_POSTGRES_URL")
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  baseUrl     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  pages       MonitoredPage[]
}

model MonitoredPage {
  id            String   @id @default(cuid())
  serviceId     String
  url           String
  pageType      String
  device        String   @default("pc")
  isActive      Boolean  @default(true)
  lastScannedAt DateTime?
  lastStatus    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  service       Service    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  snapshots     Snapshot[]
  changes       Change[]
}

model Snapshot {
  id             String   @id @default(cuid())
  pageId         String
  screenshotPath String?
  domHash        String?
  domStructure   String?  @db.Text
  capturedAt     DateTime @default(now())
  page           MonitoredPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, capturedAt(sort: Desc)])
}

model Change {
  id                   String   @id @default(cuid())
  pageId               String
  serviceName          String
  pageType             String
  category             String?
  summary              String?  @db.Text
  diffText             String?  @db.Text
  beforeScreenshotPath String?
  afterScreenshotPath  String?
  visualDiffPath       String?
  detectedAt           DateTime @default(now())
  isReviewed           Boolean  @default(false)
  page                 MonitoredPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  advice               Advice?

  @@index([detectedAt(sort: Desc)])
  @@index([serviceName])
  @@index([category])
  @@index([isReviewed])
}

model Advice {
  id             String   @id @default(cuid())
  changeId       String   @unique
  summary        String?  @db.Text
  intent         String?  @db.Text
  proposal       String?  @db.Text
  priority       String?
  expectedEffect String?  @db.Text
  risks          String?  @db.Text
  rawResponse    Json?
  createdAt      DateTime @default(now())
  change         Change @relation(fields: [changeId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt
}

model PressSource {
  id        String   @id @default(cuid())
  name      String   @unique
  url       String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  articles  PressArticle[]

  @@map("press_source")
}

model PressArticle {
  id                String    @id @default(cuid())
  sourceId          String
  title             String    @db.VarChar(512)
  articleUrl        String    @db.VarChar(2048)
  publishedAt       DateTime?
  bodyText          String?   @db.Text
  classification    String?
  relevanceCategory String?
  summary           String?   @db.VarChar(5000)
  needsManualReview Boolean   @default(false)
  scrapedAt         DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  source            PressSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, articleUrl])
  @@index([publishedAt(sort: Desc)])
  @@index([sourceId])
  @@index([classification])
  @@index([relevanceCategory])
  @@map("press_article")
}
